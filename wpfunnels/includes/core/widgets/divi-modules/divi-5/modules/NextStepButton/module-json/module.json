{
  "name": "wpfnl/next-step-button",
  "d4Shortcode": "wpfnl_next_step_button",
  "title": "WPF Next Step Button",
  "titles": "WPF Next Step Buttons",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "styleProps": {},
      "default": {},
      "settings": {
        "meta": {
          "meta": {}
        },
        "advanced": {
          "htmlAttributes": {},
          "text": {}
        },
        "decoration": {}
      }
    },
    "button": {
      "type": "object",
      "selector": "{{selector}} .et_pb_button.wpfnl-next-step-btn",
      "customPostTypeSelector": "{{baseSelector}} .et_pb_button.wpfnl-next-step-btn",
      "elementType": "button",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true,
                  "font-size": true,
                  "letter-spacing": true,
                  "line-height": true
                }
              }
            }
          }
        },
        "spacing": {
          "important": true
        }
      },
      "settings": {
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "button": {
            "component": {
              "props": {
                "dynamicSubgroupHost": true,
                "fields": {
                  "alignment": {
                    "render": false
                  },
                  "boxShadowGroup": {
                    "render": false
                  },
                  "fontGroup": {
                    "component": {
                      "props": {
                        "fields": {
                          "lineHeight": {
                            "render": true
                          },
                          "textAlign": {
                            "render": false
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "font": {},
          "sizing": {},
          "spacing": {}
        }
      }
    },
    "button_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Next Step"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "button_text.innerContent",
            "label": "Button Text",
            "render": true,
            "priority": 10,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "button_type_selector": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "checkout"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "button_type_selector.innerContent",
            "label": "Select Button Type",
            "render": true,
            "priority": 20,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "checkout": {
                    "label": "Next Step"
                  },
                  "url-path": {
                    "label": "Go To URL Path"
                  },
                  "another-funnel": {
                    "label": "Another Funnel"
                  }
                }
              }
            }
          }
        }
      }
    },
    "url_path_field": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "url_path_field.innerContent",
            "label": "URL Path",
            "description": "Only used when Button Type is 'Go To URL Path'",
            "render": true,
            "priority": 30,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "another_funnel_field": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "another_funnel_field.innerContent",
            "label": "Choose Funnel",
            "description": "Only used when Button Type is 'Another Funnel'",
            "render": true,
            "priority": 40,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "": {
                    "label": "Select funnel"
                  }
                }
              }
            }
          }
        }
      }
    },
    "button_alignment": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "center"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "button_alignment.innerContent",
            "label": "Button Alignment",
            "render": true,
            "priority": 50,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "left": {
                    "label": "Left"
                  },
                  "center": {
                    "label": "Center"
                  },
                  "right": {
                    "label": "Right"
                  }
                }
              }
            }
          }
        }
      }
    },
    "enable_subtitle": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "enable_subtitle.innerContent",
            "label": "Enable Subtitle",
            "render": true,
            "priority": 60,
            "component": {
              "type": "field",
              "name": "divi/toggle"
            }
          }
        }
      }
    },
    "subtitle_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Click to continue"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "subtitle_text.innerContent",
            "label": "Subtitle Text",
            "render": true,
            "priority": 70,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "next_step": {
      "type": "object",
      "default": {
        "desktop": {
          "value": ""
        }
      }
    },
    "subtitle": {
      "type": "object",
      "selector": "{{selector}} .wpfnl-button-subtitle",
      "elementType": "content",
      "settings": {
        "decoration": {
          "font": {},
          "spacing": {}
        }
      }
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentMain": {
        "panel": "content",
        "priority": 10,
        "groupName": "main",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Text"
          }
        }
      }
    }
  }
}