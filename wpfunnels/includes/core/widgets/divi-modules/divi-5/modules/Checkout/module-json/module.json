{
  "name": "wpfnl/checkout",
  "d4Shortcode": "wpfnl_checkout",
  "title": "WPF Checkout",
  "titles": "WPF Checkouts",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "styleProps": {},
      "default": {},
      "settings": {
        "meta": {
          "meta": {}
        },
        "advanced": {
          "htmlAttributes": {}
        },
        "decoration": {
          "background": {},
          "spacing": {},
          "boxShadow": {},
          "filters": {},
          "transform": {},
          "animation": {},
          "disabledOn": {},
          "transition": {},
          "position": {},
          "zIndex": {},
          "scroll": {},
          "sticky": {}
        }
      }
    },
    "checkout_layout": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "wpfnl-col-2"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "checkout_layout.innerContent",
            "label": "Layout",
            "render": true,
            "priority": 10,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "wpfnl-col-1": {
                    "label": "1 Column Checkout"
                  },
                  "wpfnl-col-2": {
                    "label": "2 Column Checkout"
                  },
                  "wpfnl-2-step": {
                    "label": "2 Step Checkout"
                  },
                  "wpfnl-modern-multistep": {
                    "label": "Modern Multistep Checkout"
                  },
                  "wpfnl-express-checkout": {
                    "label": "Express Checkout"
                  },
                  "wpfnl-modern-checkout": {
                    "label": "Modern Checkout"
                  },
                  "wpfnl-modern-one-column": {
                    "label": "Modern One Column Checkout"
                  }
                }
              }
            }
          }
        }
      }
    },
    "checkout_floating_label": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": ""
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "checkout_floating_label.innerContent",
            "label": "Floating Label",
            "render": true,
            "priority": 20,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "": {
                    "label": "None"
                  },
                  "floating-label": {
                    "label": "Floating Label"
                  }
                }
              }
            }
          }
        }
      }
    },
    "enable_order_summary": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "enable_order_summary.innerContent",
            "label": "Show Order Summary",
            "render": false,
            "priority": 30,
            "component": {
              "type": "field",
              "name": "divi/toggle"
            }
          }
        }
      }
    },
    "show_coupon_field": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "on"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "show_coupon_field.innerContent",
            "label": "Show Coupon Field",
            "render": false,
            "priority": 40,
            "component": {
              "type": "field",
              "name": "divi/toggle"
            }
          }
        }
      }
    },
    "place_order_button_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Place Order"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "place_order_button_text.innerContent",
            "label": "Place Order Button Text",
            "render": false,
            "priority": 50,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "order_button": {
      "type": "object",
      "selector": "{{selector}} #payment #place_order",
      "elementType": "button",
      "styleProps": {
        "spacing": {
          "important": true
        }
      },
      "settings": {
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "button": {},
          "font": {},
          "sizing": {},
          "spacing": {}
        }
      }
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentMain": {
        "panel": "content",
        "priority": 10,
        "groupName": "main",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Layout"
          }
        }
      }
    }
  }
}
