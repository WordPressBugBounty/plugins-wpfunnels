{
  "name": "wpfnl/offer-button",
  "d4Shortcode": "wpfnl_offer_button",
  "title": "WPF Offer Button",
  "titles": "WPF Offer Buttons",
  "category": "module",
  "attributes": {
    "module": {
      "type": "object",
      "selector": "{{selector}}",
      "styleProps": {},
      "default": {},
      "settings": {
        "meta": {
          "meta": {}
        },
        "advanced": {
          "htmlAttributes": {},
          "text": {}
        },
        "decoration": {}
      }
    },
    "button": {
      "type": "object",
      "selector": "{{selector}} .et_pb_button.wpfnl-offer-btn",
      "customPostTypeSelector": "{{baseSelector}} .et_pb_button.wpfnl-offer-btn",
      "elementType": "button",
      "styleProps": {
        "font": {
          "important": {
            "font": {
              "desktop": {
                "value": {
                  "color": true,
                  "font-size": true,
                  "letter-spacing": true,
                  "line-height": true
                }
              }
            }
          }
        },
        "spacing": {
          "important": true
        }
      },
      "settings": {
        "decoration": {
          "background": {},
          "border": {},
          "boxShadow": {},
          "button": {
            "component": {
              "props": {
                "dynamicSubgroupHost": true,
                "fields": {
                  "alignment": {
                    "render": false
                  },
                  "boxShadowGroup": {
                    "render": false
                  },
                  "fontGroup": {
                    "component": {
                      "props": {
                        "fields": {
                          "lineHeight": {
                            "render": true
                          },
                          "textAlign": {
                            "render": false
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "font": {},
          "sizing": {},
          "spacing": {}
        }
      }
    },
    "offer_button_type": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "upsell"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "offer_button_type.innerContent",
            "label": "Select Button Type",
            "render": true,
            "priority": 10,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "upsell": {
                    "label": "Upsell"
                  },
                  "downsell": {
                    "label": "Downsell"
                  }
                }
              }
            }
          }
        }
      }
    },
    "offer_action": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "accept"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "offer_action.innerContent",
            "label": "Select Button Action",
            "render": true,
            "priority": 20,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "accept": {
                    "label": "Accept"
                  },
                  "reject": {
                    "label": "Reject"
                  }
                }
              }
            }
          }
        }
      }
    },
    "accept_button_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "Yes, Add to My Order!"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "accept_button_text.innerContent",
            "label": "Accept Button Text",
            "render": true,
            "priority": 30,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "reject_button_text": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "No Thanks"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "reject_button_text.innerContent",
            "label": "Reject Button Text",
            "render": true,
            "priority": 40,
            "component": {
              "type": "field",
              "name": "divi/text"
            }
          }
        }
      }
    },
    "show_product_price": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "off"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "show_product_price.innerContent",
            "label": "Show Product Price",
            "description": "Show product price (only for accept button)",
            "render": true,
            "priority": 50,
            "component": {
              "type": "field",
              "name": "divi/toggle"
            }
          }
        }
      }
    },
    "button_alignment": {
      "type": "object",
      "default": {
        "innerContent": {
          "desktop": {
            "value": "left"
          }
        }
      },
      "settings": {
        "innerContent": {
          "groupType": "group-item",
          "item": {
            "groupSlug": "contentMain",
            "attrName": "button_alignment.innerContent",
            "label": "Button Alignment",
            "render": true,
            "priority": 60,
            "component": {
              "type": "field",
              "name": "divi/select",
              "props": {
                "options": {
                  "left": {
                    "label": "Left"
                  },
                  "center": {
                    "label": "Center"
                  },
                  "right": {
                    "label": "Right"
                  }
                }
              }
            }
          }
        }
      }
    },
    "price": {
      "type": "object",
      "selector": "{{selector}} .wpfnl-offer-product-price",
      "elementType": "content",
      "settings": {
        "decoration": {
          "font": {},
          "spacing": {}
        }
      }
    }
  },
  "settings": {
    "content": "auto",
    "design": "auto",
    "advanced": "auto",
    "groups": {
      "contentMain": {
        "panel": "content",
        "priority": 10,
        "groupName": "main",
        "multiElements": true,
        "component": {
          "name": "divi/composite",
          "props": {
            "groupLabel": "Button Settings"
          }
        }
      }
    }
  }
}